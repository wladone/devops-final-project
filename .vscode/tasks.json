      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/jenkins/start.ps1"
      ]
    },
    {
      "label": "Stop Local Jenkins",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/jenkins/stop.ps1"
      ]
    },
    {
      "label": "Jenkins Logs",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/jenkins/logs.ps1"
      ]
