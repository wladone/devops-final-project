{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Check Prerequisites",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/check_prereqs.ps1"
      ]
    },
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/setup_venv.ps1"
      ]
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/run_tests.ps1"
      ],
      "group": "test"
    },
    {
      "label": "Run Data Quality Pipeline",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/run_pipeline.ps1"
      ],
      "group": "build"
    },
    {
      "label": "Run Dashboard",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/run_dashboard.ps1"
      ]
    },
    {
