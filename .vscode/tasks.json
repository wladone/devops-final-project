      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/gitops/start.ps1"
      ]
    },
    {
      "label": "Bootstrap Local GitOps Repo",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/gitops/bootstrap_local_repo.ps1"
      ]
    },
    {
      "label": "Install Argo CD In Cluster",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/gitops/install_argocd.ps1"
      ]
    },
    {
      "label": "Bootstrap GitOps App",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/gitops/bootstrap_app.ps1"
      ]
    }
  ]
}
